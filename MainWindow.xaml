<Window x:Class="Dockview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Dockview"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Dockview"
        Width="1280" Height="720"
        MinWidth="640" MinHeight="360"
        Background="{DynamicResource AppBackground}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

    <!-- Extend client area into the title bar.
         CaptionHeight matches TopBar height so the gradient covers the whole strip.
         The OS still draws its min/max/close buttons on top (top-right corner). -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="56"
                            ResizeBorderThickness="4"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Window.Resources>

    <!--
        Root grid: video fills everything; overlay panels sit on top.
        Auto-hide: DispatcherTimer in code-behind sets panel Opacity to 0 after
        3 s of mouse inactivity when in fullscreen mode.
    -->
    <Grid x:Name="RootGrid" MouseMove="RootGrid_MouseMove">

        <!-- ── 1. VIDEO AREA ─────────────────────────────────────────────── -->
        <Grid Background="Black" ClipToBounds="True">

            <!-- Live frame — WriteableBitmap (Bgr32) bound from MainViewModel -->
            <Image x:Name="VideoImage"
                   Source="{Binding PreviewBitmap}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="{Binding BitmapScalingMode}"
                   UseLayoutRounding="True"/>

            <!-- No-Signal overlay — visible when IsCapturing = false -->
            <Grid Visibility="{Binding IsCapturing,
                               Converter={StaticResource InverseBoolToVisibility}}">
                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.80"/>
                </Grid.Background>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="□"
                               FontSize="56"
                               HorizontalAlignment="Center"
                               Foreground="#333"
                               FontFamily="Segoe UI Symbol"/>
                    <TextBlock Text="{Binding StatusText}"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                               FontSize="15"
                               Foreground="#777"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ── 2. TOP BAR ────────────────────────────────────────────────── -->
        <Border x:Name="TopBar"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Height="56"
                Padding="16,0,4,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#D0000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App branding + live dot -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Ellipse x:Name="LiveDot" Width="7" Height="7" Margin="0,0,9,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#EF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                        <Setter Property="Fill" Value="#22C55E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Dockview"
                               Foreground="White"
                               FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Device selectors -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="16,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">

                    <TextBlock Text="VIDEO"
                               Foreground="#88FFFFFF"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              Width="210"
                              ItemsSource="{Binding VideoDevices}"
                              SelectedItem="{Binding SelectedVideoDevice}"
                              DisplayMemberPath="FriendlyName"/>

                    <Rectangle Width="1" Margin="14,6" Fill="#44FFFFFF"/>

                    <TextBlock Text="AUDIO"
                               Foreground="#88FFFFFF"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              Width="210"
                              ItemsSource="{Binding AudioDevices}"
                              SelectedItem="{Binding SelectedAudioDevice}"
                              DisplayMemberPath="FriendlyName"/>
                </StackPanel>

                <!-- Action buttons + Window caption buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,2,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="⟳"
                            Style="{StaticResource IconButtonStyle}"
                            Foreground="White" FontSize="16"
                            Width="32" Height="32" Padding="0"
                            ToolTip="Refresh device list"
                            Command="{Binding RefreshDevicesCommand}"
                            Margin="0,0,2,0"/>
                    <Button Content="{Binding PresetLabel}"
                            Style="{StaticResource IconButtonStyle}"
                            Foreground="White" FontSize="15"
                            Width="32" Height="32" Padding="0"
                            ToolTip="{Binding RenderPreset}"
                            Click="PresetButton_Click"
                            Margin="0,0,2,0"/>
                    <Button Content="⛶"
                            Style="{StaticResource IconButtonStyle}"
                            Foreground="White" FontSize="15"
                            Width="32" Height="32" Padding="0"
                            ToolTip="Toggle fullscreen  (F11)"
                            Click="FullscreenButton_Click"/>

                    <Rectangle Width="1" Margin="10,8" Fill="#44FFFFFF"/>

                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource IconButtonStyle}"
                            Content="─"
                            Foreground="White" FontSize="15"
                            Width="32" Height="32" Padding="0"
                            ToolTip="Minimizar"
                            Margin="0,0,2,0"
                            Click="MinimizeButton_Click"/>
                    <Button x:Name="MaxRestoreButton"
                            Style="{StaticResource IconButtonStyle}"
                            Content="□"
                            Foreground="White" FontSize="13"
                            Width="32" Height="32" Padding="0"
                            ToolTip="Maximizar"
                            Margin="0,0,2,0"
                            Click="MaxRestoreButton_Click"/>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource CloseButtonStyle}"
                            Content="✕"
                            Foreground="White" FontSize="13"
                            Width="32" Height="32" Padding="0"
                            ToolTip="Cerrar"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 3. BOTTOM CONTROLS OVERLAY ───────────────────────────────── -->
        <Border x:Name="BottomOverlay"
                VerticalAlignment="Bottom"
                Padding="20,14,20,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Color="#D8000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto" MinWidth="120"/>
                </Grid.ColumnDefinitions>

                <!-- ── Volume ── -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="VOLUME"
                               Foreground="#77FFFFFF"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔈"
                                   FontSize="13"
                                   Foreground="#AAFFFFFF"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Slider Style="{StaticResource VolumeSlider}"
                                Width="90"
                                Minimum="0" Maximum="1"
                                Value="{Binding Volume}"
                                VerticalAlignment="Center"/>
                        <TextBlock Foreground="#BBFFFFFF"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Width="38"
                                   Margin="8,0,0,0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:P0}">
                                    <Binding Path="Volume"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- ── Audio Sync ── -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="AUDIO SYNC"
                                   Foreground="#77FFFFFF"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="+ 300 ms"
                                   Foreground="#44FFFFFF"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   FontSize="10"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="− 300 ms"
                                   Foreground="#44FFFFFF"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   FontSize="10"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                        <TextBlock Text="{Binding AudioOffsetLabel}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <Slider Style="{StaticResource ModernSlider}"
                            Minimum="-300" Maximum="300"
                            Value="{Binding AudioOffsetMs}"
                            TickFrequency="25"
                            IsSnapToTickEnabled="False"
                            ToolTip="Drag left/right to fix audio desync"/>
                </StackPanel>

                <!-- ── Status chip ── -->
                <Border Grid.Column="4"
                        CornerRadius="14"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"     Value="#33EF4444"/>
                            <Setter Property="BorderBrush"    Value="#55EF4444"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                    <Setter Property="Background"  Value="#2222C55E"/>
                                    <Setter Property="BorderBrush" Value="#5522C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText}"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   FontSize="11"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FpsText}"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   FontSize="10"
                                   Foreground="#AAFFFFFF"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding IsCapturing,
                                       Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="{Binding StreamInfoText}"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   FontSize="9"
                                   Foreground="#77FFFFFF"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding IsCapturing,
                                       Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>
