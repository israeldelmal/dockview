<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Semantic brushes.  Values here are the dark-mode defaults.
        App.xaml.cs swaps them at runtime based on the Windows system theme.
    -->

    <SolidColorBrush x:Key="AppBackground"      Color="#0F0F0F"/>
    <SolidColorBrush x:Key="SurfaceBackground"  Color="#CC1A1A1A"/>
    <SolidColorBrush x:Key="OverlayBackground"  Color="#D0101010"/>
    <SolidColorBrush x:Key="PrimaryText"        Color="#F2F2F2"/>
    <SolidColorBrush x:Key="SecondaryText"      Color="#8A8A8A"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="#00AAFF"/>
    <SolidColorBrush x:Key="HoverBackground"    Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxBackground" Color="#99202020"/>
    <SolidColorBrush x:Key="SliderTrackBrush"   Color="#404040"/>

    <!-- Constant colours -->
    <SolidColorBrush x:Key="LiveGreen"          Color="#22C55E"/>
    <SolidColorBrush x:Key="ErrorRed"           Color="#EF4444"/>
    <SolidColorBrush x:Key="Transparent"        Color="Transparent"/>

</ResourceDictionary>
